# =====================================================
# LOYIHA IDENTIFIKATORI
# Bir serverda bir nechta loyiha ishlatilganda
# har bir loyiha uchun UNIQUE nom berish shart.
# Docker shu nom orqali container/volume/network
# nomlarini avtomatik ajratadi.
# =====================================================
COMPOSE_PROJECT_NAME=template

# =====================================================
# TASHQI PORTLAR
# Bir serverda bir nechta loyiha bo'lsa har birida
# boshqa raqam ishlatilsin (konflikt bo'lmasligi uchun).
# Ichki servislar (db, redis, backend) port ochmaydi.
# =====================================================
NGINX_PORT=8001
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8001/api

# django
SECRET_KEY=KEY
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# database
# SQLite uchun: USE_POSTGRES=False  →  docker compose up
# PostgreSQL uchun: USE_POSTGRES=True  →  docker compose --profile postgres up
USE_POSTGRES=False

DB_NAME=django_db
DB_USER=postgres
DB_PORT=5432
DB_HOST=db
DB_PASSWORD=postgres

# redis / cache
REDIS_URL=redis://redis:6379/0

# cors (FRONTEND_PORT bilan mos bo'lishi shart)
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:8001,http://127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_HEADERS=content-type,authorization
CORS_ALLOW_CREDENTIALS=True

# email
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# bot
BOT_SECRET=changeme-shared-secret

# yandex
YANDEX_MAPS_API_KEY=
